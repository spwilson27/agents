#!/usr/bin/env python3
"""CLI tool for managing AI agent instruction files across different agent CLIs."""

import argparse
import os
import sys

SOURCE_FILE = os.path.join(".agents", "AGENT.md")

# Mapping of CLI name -> project-root-relative destination path
TARGETS = {
    "claude": "CLAUDE.md",
    "codex": "AGENTS.md",
    "gemini": "GEMINI.md",
    "copilot": os.path.join(".github", "copilot-instructions.md"),
    "qwen": "QWEN.md",
    "opencode": "AGENTS.md",  # same as codex
}


def doc(root: str) -> None:
    source = os.path.join(root, SOURCE_FILE)
    if not os.path.isfile(source):
        print(f"error: {SOURCE_FILE} not found", file=sys.stderr)
        sys.exit(1)

    content = open(source).read()

    seen_paths: set[str] = set()
    for _, rel in TARGETS.items():
        dest = os.path.join(root, rel)
        if dest in seen_paths:
            continue
        seen_paths.add(dest)
        os.makedirs(os.path.dirname(dest) or ".", exist_ok=True)
        with open(dest, "w") as f:
            f.write(content)
        print(f"  {rel}")


def main(argv: list[str] | None = None) -> None:
    parser = argparse.ArgumentParser(prog="agents", description="Manage AI agent instruction files.")
    sub = parser.add_subparsers(dest="command")

    doc_parser = sub.add_parser("doc", help="Copy .agents/AGENT.md to all agent CLI instruction files.")
    doc_parser.add_argument("--root", default=".", help="Project root directory.")

    args = parser.parse_args(argv)

    if args.command == "doc":
        doc(args.root)
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
